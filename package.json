{
  "name": "lyn-linear",
  "version": "0.1.1",
  "description": "CLI that bridges Linear with git workflows and Claude Code — automate tickets, branches, PRs, and give your AI agent project management context",
  "type": "module",
  "bin": {
    "lyn": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "linear",
    "cli",
    "git",
    "claude",
    "claude-code",
    "ai",
    "project-management",
    "workflow",
    "developer-tools"
  ],
  "author": "laspencer91",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/laspencer91/lyn-cli.git"
  },
  "homepage": "https://github.com/laspencer91/lyn-cli#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@linear/sdk": "^76.0.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "simple-git": "^3.32.3",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
